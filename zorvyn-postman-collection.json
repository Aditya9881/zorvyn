{
  "info": {
    "_postman_id": "zorvyn-api-collection",
    "name": "Zorvyn Financial API",
    "description": "Complete API collection for the Zorvyn financial dashboard backend. 26 endpoints across Auth, Transactions, Analytics, Budgets, and Admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecureP@ss123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecureP@ss123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "description": "Uses HttpOnly cookie from login response. Send this from a browser or set the cookie manually."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"150.75\",\n  \"type\": \"expense\",\n  \"category\": \"Groceries\",\n  \"date\": \"2026-04-01\",\n  \"note\": \"Weekly shopping\"\n}"
            }
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "category", "value": "Groceries", "disabled": true },
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true },
                { "key": "cursor", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"175.00\",\n  \"category\": \"Organic Groceries\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] }
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions/export",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "export"],
              "query": [
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Financial Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/summary",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "summary"],
              "query": [
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Category Breakdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/analytics/categories", "host": ["{{baseUrl}}"], "path": ["analytics", "categories"] }
          }
        },
        {
          "name": "Monthly Trends",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/trends?year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "trends"],
              "query": [{ "key": "year", "value": "2026" }]
            }
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Set Budget",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Groceries\",\n  \"limit\": \"500.00\",\n  \"yearMonth\": \"2026-04\"\n}"
            }
          }
        },
        {
          "name": "Get Budgets (with Remaining)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/budgets?yearMonth=2026-04",
              "host": ["{{baseUrl}}"],
              "path": ["budgets"],
              "query": [{ "key": "yearMonth", "value": "2026-04" }]
            }
          }
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/budgets/1", "host": ["{{baseUrl}}"], "path": ["budgets", "1"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/1", "host": ["{{baseUrl}}"], "path": ["users", "1"] }
          }
        },
        {
          "name": "Assign Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/users/2/roles", "host": ["{{baseUrl}}"], "path": ["users", "2", "roles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"Analyst\"\n}"
            }
          }
        },
        {
          "name": "Remove Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/2/roles/Analyst", "host": ["{{baseUrl}}"], "path": ["users", "2", "roles", "Analyst"] }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/2/deactivate", "host": ["{{baseUrl}}"], "path": ["users", "2", "deactivate"] }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/2/activate", "host": ["{{baseUrl}}"], "path": ["users", "2", "activate"] }
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                { "key": "actorId", "value": "1", "disabled": true },
                { "key": "resourceType", "value": "transaction", "disabled": true },
                { "key": "limit", "value": "50", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Infrastructure",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
