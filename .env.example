# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/zorvyn.db

# JWT Secrets (generate strong random values for production)
ACCESS_TOKEN_SECRET=change-me-access-secret-min-32-chars
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars

# Token Expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
